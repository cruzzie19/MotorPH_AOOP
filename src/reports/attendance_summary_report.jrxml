<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="attendance_summary_report" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20"
              uuid="b1a1c1a0-0000-0000-0000-000000000003">

    <parameter name="reportTitle" class="java.lang.String"/>
    <parameter name="generatedBy" class="java.lang.String"/>
    <parameter name="generatedOn" class="java.lang.String"/>

    <field name="employeeId" class="java.lang.String"/>
    <field name="employeeName" class="java.lang.String"/>
    <field name="daysPresent" class="java.lang.Integer"/>
    <field name="lateCount" class="java.lang.Integer"/>
    <field name="totalHours" class="java.math.BigDecimal"/>
    <field name="averageTimeIn" class="java.lang.String"/>

    <sortField name="employeeId"/>

    <variable name="employeeCount" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{employeeId}]]></variableExpression>
    </variable>
    <variable name="totalDaysPresent" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{daysPresent}]]></variableExpression>
    </variable>
    <variable name="totalLate" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{lateCount}]]></variableExpression>
    </variable>

    <title>
        <band height="70">
            <textField>
                <reportElement x="0" y="0" width="535" height="28"/>
                <textElement>
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="32" width="535" height="16"/>
                <textElement>
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{generatedBy} + "    |    Generated on: " + $P{generatedOn}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="50" width="535" height="14"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isItalic="true"/>
                </textElement>
                <text><![CDATA[Late = time-in after 8:00 AM. Summary covers the visible attendance records as of generation time.]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="22" backcolor="#222222" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="70" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Employee ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="70" y="0" width="150" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="220" y="0" width="85" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Days Present]]></text>
            </staticText>
            <staticText>
                <reportElement x="305" y="0" width="70" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Late Count]]></text>
            </staticText>
            <staticText>
                <reportElement x="375" y="0" width="80" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Total Hours]]></text>
            </staticText>
            <staticText>
                <reportElement x="455" y="0" width="80" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Avg Time-In]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0" y="0" width="70" height="22"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="70" y="0" width="150" height="22"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="220" y="0" width="85" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{daysPresent}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="305" y="0" width="70" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{lateCount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="375" y="0" width="80" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{totalHours}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="455" y="0" width="80" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{averageTimeIn}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="21" width="535" height="1" forecolor="#DDDDDD"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="6" width="535" height="18"/>
                <textElement><font fontName="SansSerif" size="10" isItalic="true"/></textElement>
                <textFieldExpression><![CDATA["Employees: " + $V{employeeCount} + "    Total days present: " + $V{totalDaysPresent} + "    Total late instances: " + $V{totalLate}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="535" height="16"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
