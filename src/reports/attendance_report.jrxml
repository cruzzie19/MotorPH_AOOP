<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="attendance_report" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20"
              uuid="b1a1c1a0-0000-0000-0000-000000000001">

    <parameter name="reportTitle" class="java.lang.String"/>
    <parameter name="generatedBy" class="java.lang.String"/>
    <parameter name="generatedOn" class="java.lang.String"/>

    <field name="employeeId" class="java.lang.String"/>
    <field name="employeeName" class="java.lang.String"/>
    <field name="date" class="java.lang.String"/>
    <field name="logIn" class="java.lang.String"/>
    <field name="logOut" class="java.lang.String"/>

    <sortField name="employeeId"/>
    <sortField name="date"/>

    <variable name="recordCount" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{employeeId}]]></variableExpression>
    </variable>

    <group name="EmployeeGroup">
        <groupExpression><![CDATA[$F{employeeId}]]></groupExpression>
        <groupHeader>
            <band height="26">
                <rectangle>
                    <reportElement x="0" y="2" width="535" height="20" backcolor="#E8E8E8" mode="Opaque"/>
                    <graphicElement><pen lineWidth="0.0"/></graphicElement>
                </rectangle>
                <textField>
                    <reportElement x="6" y="2" width="529" height="20"/>
                    <textElement verticalAlignment="Middle">
                        <font fontName="SansSerif" size="11" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Employee: " + $F{employeeId} + "  -  " + $F{employeeName}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="10"/>
        </groupFooter>
    </group>

    <title>
        <band height="70">
            <textField>
                <reportElement x="0" y="0" width="535" height="28"/>
                <textElement>
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="32" width="535" height="16"/>
                <textElement>
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{generatedBy} + "    |    Generated on: " + $P{generatedOn}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="55" width="535" height="1"/>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="22" backcolor="#222222" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="100" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Employee ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="0" width="175" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="275" y="0" width="100" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="375" y="0" width="80" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Time In]]></text>
            </staticText>
            <staticText>
                <reportElement x="455" y="0" width="80" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Time Out]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="100" height="20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="100" y="0" width="175" height="20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="275" y="0" width="100" height="20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="375" y="0" width="80" height="20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{logIn}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="455" y="0" width="80" height="20"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{logOut}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="19" width="535" height="1" forecolor="#DDDDDD"/>
            </line>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="535" height="16"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="6" width="535" height="18"/>
                <textElement><font fontName="SansSerif" size="10" isItalic="true"/></textElement>
                <textFieldExpression><![CDATA["Total records: " + $V{recordCount}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
