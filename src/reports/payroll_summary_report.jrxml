<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="payroll_summary_report" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20"
              uuid="b1a1c1a0-0000-0000-0000-000000000004">

    <parameter name="reportTitle" class="java.lang.String"/>
    <parameter name="generatedBy" class="java.lang.String"/>
    <parameter name="generatedOn" class="java.lang.String"/>

    <field name="department" class="java.lang.String"/>
    <field name="employeeCount" class="java.lang.Integer"/>
    <field name="payslipCount" class="java.lang.Integer"/>
    <field name="totalGrossPay" class="java.math.BigDecimal"/>
    <field name="totalDeductions" class="java.math.BigDecimal"/>
    <field name="totalNetPay" class="java.math.BigDecimal"/>

    <sortField name="department"/>

    <variable name="grandTotalNetPay" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{totalNetPay}]]></variableExpression>
    </variable>
    <variable name="grandTotalEmployees" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{employeeCount}]]></variableExpression>
    </variable>

    <title>
        <band height="70">
            <textField>
                <reportElement x="0" y="0" width="535" height="28"/>
                <textElement>
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="32" width="535" height="16"/>
                <textElement>
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated by: " + $P{generatedBy} + "    |    Generated on: " + $P{generatedOn}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="50" width="535" height="14"/>
                <textElement>
                    <font fontName="SansSerif" size="9" isItalic="true"/>
                </textElement>
                <text><![CDATA[Department reflects each employee's assigned role.]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="22" backcolor="#222222" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="135" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Department]]></text>
            </staticText>
            <staticText>
                <reportElement x="135" y="0" width="75" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Employees]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="0" width="75" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Payslips]]></text>
            </staticText>
            <staticText>
                <reportElement x="285" y="0" width="83" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Gross Pay]]></text>
            </staticText>
            <staticText>
                <reportElement x="368" y="0" width="83" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Deductions]]></text>
            </staticText>
            <staticText>
                <reportElement x="451" y="0" width="84" height="22" forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Net Pay]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField>
                <reportElement x="0" y="0" width="135" height="22"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{department}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="135" y="0" width="75" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeCount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="210" y="0" width="75" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Center"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{payslipCount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="285" y="0" width="83" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{totalGrossPay}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="368" y="0" width="83" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{totalDeductions}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="451" y="0" width="84" height="22"/>
                <textElement verticalAlignment="Middle" textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{totalNetPay}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="21" width="535" height="1" forecolor="#DDDDDD"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="6" width="300" height="18"/>
                <textElement><font fontName="SansSerif" size="10" isItalic="true"/></textElement>
                <textFieldExpression><![CDATA["Total employees: " + $V{grandTotalEmployees}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="368" y="6" width="167" height="18"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="11" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Grand Total Net Pay: " + $V{grandTotalNetPay}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="535" height="16"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
